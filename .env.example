# ─────────────────────────────────────────────────────────────────────────────
# OpsSweep environment variable template
# Copy this file to .env and fill in your values.
# Viper reads these with the OPSSWEEP_ prefix (e.g. OPSSWEEP_REGION).
# ─────────────────────────────────────────────────────────────────────────────

# ─── AWS credentials ─────────────────────────────────────────────────────────
# Prefer ~/.aws/credentials or IAM roles. Only set these for local overrides.
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SESSION_TOKEN=                        # optional; required for assumed roles

# ─── AWS targeting ───────────────────────────────────────────────────────────
# Named profile from ~/.aws/credentials (leave blank to use the default profile)
AWS_PROFILE=

# Comma-separated list of regions to scan. Leave blank to scan all enabled regions.
OPSSWEEP_REGION=

# ─── Scan behaviour ──────────────────────────────────────────────────────────
# Lookback window in days for CloudWatch utilization metrics (default: 14)
OPSSWEEP_DAYS=14

# Minimum idle confidence score to flag a resource, 0.0–1.0 (default: 0.6)
OPSSWEEP_THRESHOLD=0.6

# ─── Output ──────────────────────────────────────────────────────────────────
# Set to "true" to emit JSON instead of a styled terminal table
OPSSWEEP_JSON=false

# Set to "true" to disable redaction of account IDs and ARNs in reports
OPSSWEEP_NO_REDACT=false

# Path for the generated HTML report (default: ./opssweep-report.html)
OPSSWEEP_REPORT_OUTPUT=

# ─── Local state directory ───────────────────────────────────────────────────
# Directory for the audit journal and scan history (default: ~/.opssweep/)
OPSSWEEP_STATE_DIR=

# ─── Teardown safety ─────────────────────────────────────────────────────────
# Set to "true" to skip pre-deletion snapshots (strongly discouraged)
OPSSWEEP_NO_SNAPSHOT=false
