<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>OpsSweep FinOps Audit Report</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-800 min-h-screen">

  <!-- ── Header ─────────────────────────────────────────────────────────── -->
  <header class="bg-gray-900 text-white py-8 px-6 shadow-lg">
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold tracking-tight">
          🧹 OpsSweep
          <span class="ml-2 text-gray-400 font-normal text-xl">FinOps Audit Report</span>
        </h1>
        <p class="mt-1 text-sm text-gray-400">Generated on {{.ScanDate}}</p>
      </div>
      <div class="text-right">
        <span class="inline-block bg-red-600 text-white text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wide">
          {{.ResourceCount}} resources flagged
        </span>
      </div>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-6 py-10 space-y-10">

    <!-- ── Summary hero ────────────────────────────────────────────────── -->
    <section class="grid grid-cols-1 sm:grid-cols-2 gap-6">

      <!-- Total monthly waste -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 flex flex-col items-center justify-center text-center">
        <p class="text-sm font-medium text-gray-500 uppercase tracking-widest mb-2">Estimated Monthly Waste</p>
        <p class="text-6xl font-extrabold text-red-600">${{printf "%.2f" .TotalWaste}}</p>
        <p class="mt-2 text-sm text-gray-400">per month · confidence ≥ 90%</p>
      </div>

      <!-- Resource count -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 flex flex-col items-center justify-center text-center">
        <p class="text-sm font-medium text-gray-500 uppercase tracking-widest mb-2">Idle Resources Found</p>
        <p class="text-6xl font-extrabold text-amber-500">{{.ResourceCount}}</p>
        <p class="mt-2 text-sm text-gray-400">across all scanned regions</p>
      </div>

    </section>

    <!-- ── Resource table ──────────────────────────────────────────────── -->
    <section>
      <h2 class="text-xl font-semibold text-gray-700 mb-4">Flagged Resources</h2>

      {{if eq .ResourceCount 0}}
      <div class="bg-green-50 border border-green-200 rounded-2xl p-10 text-center">
        <p class="text-green-700 font-semibold text-lg">✅ No high-confidence idle resources found.</p>
        <p class="text-green-600 text-sm mt-1">All scanned resources appear to be in active use.</p>
      </div>
      {{else}}
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-100 text-gray-600 uppercase text-xs tracking-wider">
              <th class="px-6 py-4 text-left font-semibold">Resource Type</th>
              <th class="px-6 py-4 text-left font-semibold">Resource ID</th>
              <th class="px-6 py-4 text-left font-semibold">Region</th>
              <th class="px-6 py-4 text-left font-semibold">Confidence</th>
              <th class="px-6 py-4 text-right font-semibold">Monthly Waste</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {{range .Resources}}
            <tr class="hover:bg-gray-50 transition-colors duration-100">

              <!-- Resource type badge -->
              <td class="px-6 py-4">
                <span class="inline-block bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-1 rounded-full">
                  {{.ResourceType}}
                </span>
              </td>

              <!-- Resource ID — monospace for readability -->
              <td class="px-6 py-4">
                <code class="font-mono text-gray-700 text-xs bg-gray-50 px-2 py-0.5 rounded">{{.ID}}</code>
              </td>

              <!-- Region -->
              <td class="px-6 py-4 text-gray-600">{{.Region}}</td>

              <!-- Confidence score with colour-coded pill -->
              <td class="px-6 py-4">
                {{if ge .ConfidenceScore 1.0}}
                  <span class="inline-block bg-red-100 text-red-700 text-xs font-bold px-2.5 py-1 rounded-full">
                    {{printf "%.0f%%" (mul .ConfidenceScore 100.0)}}
                  </span>
                {{else}}
                  <span class="inline-block bg-amber-100 text-amber-700 text-xs font-bold px-2.5 py-1 rounded-full">
                    {{printf "%.0f%%" (mul .ConfidenceScore 100.0)}}
                  </span>
                {{end}}
              </td>

              <!-- Monthly waste — right-aligned, bold red -->
              <td class="px-6 py-4 text-right font-semibold text-red-600">
                ${{printf "%.2f" .MonthlyWaste}}<span class="text-gray-400 font-normal">/mo</span>
              </td>

            </tr>

            <!-- Reason sub-row -->
            {{if .Reasons}}
            <tr class="bg-gray-50">
              <td colspan="5" class="px-6 py-2">
                <ul class="flex flex-wrap gap-2">
                  {{range .Reasons}}
                  <li class="text-xs text-gray-500 bg-white border border-gray-200 rounded px-2 py-0.5">
                    {{.}}
                  </li>
                  {{end}}
                </ul>
              </td>
            </tr>
            {{end}}

            {{end}}
          </tbody>
        </table>
      </div>
      {{end}}
    </section>

  </main>

  <!-- ── Footer ─────────────────────────────────────────────────────────── -->
  <footer class="max-w-6xl mx-auto px-6 pb-10 text-center text-xs text-gray-400">
    Generated by <strong>OpsSweep</strong> · Cost estimates are representative heuristics and may differ from your actual AWS bill.
  </footer>

</body>
</html>
